# Copy this file to .env.local and fill in the values. .env.local is
# gitignored, so your real keys never get committed.

# ---- Spotify (optional — only needed for Spotify-Linked Mode) --------
VITE_SPOTIFY_CLIENT_ID=

# ---- Supabase (required) ---------------------------------------------
# Find these under: Supabase dashboard → Project Settings → API
#   * Project URL        →  VITE_SUPABASE_URL
#   * anon / public key  →  VITE_SUPABASE_ANON_KEY
# The anon key is safe to ship to the browser — RLS enforces auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
